.activity-card.core-card.completed .activity-title {
  color: #065f46;
  text-decoration: none !important;   /* kill any old line-through */
}
.activity-card.core-card.completed .activity-icon {
  filter: drop-shadow(0 4px 10px rgba(16,185,129,.25));
}

/* Tiny “Next”/“Done” pills on the left label (no HTML changes) */
