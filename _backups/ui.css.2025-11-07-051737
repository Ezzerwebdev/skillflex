.sf-modal{width:min(880px,92vw);max-height:88vh;overflow:auto;background:#0f172a;color:#e2e8f0;border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,.35)}
.sf-head{padding:18px 22px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;gap:10px}
.sf-head h3{margin:0;font-size:20px}
.sf-body{padding:22px}
.sf-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px}
.sf-card{position:relative;border-radius:16px;border:1px solid rgba(255,255,255,.08);padding:16px 14px;background:rgba(255,255,255,.02);cursor:pointer;transition:.15s transform ease,.15s box-shadow ease}
.sf-card:hover{transform:translateY(-2px)}
.sf-card .title{font-weight:800;font-size:18px;margin:8px 0}
.sf-card .sub{opacity:.8;font-size:13px;margin-top:4px}
.sf-badge{position:absolute;top:10px;right:10px;font-size:12px;border-radius:999px;padding:.2rem .5rem;border:1px solid rgba(255,255,255,.15)}
.sf-badge.lock{background:#1f2937;color:#9ca3af;border-color:#374151}
.sf-badge.ok{background:#14b8a6;color:#042f2e;border-color:#0d9488}
.sf-foot{padding:14px 22px;border-top:1px solid rgba(255,255,255,.08);display:flex;justify-content:flex-end;gap:10px}
.sf-btn{appearance:none;border:0;border-radius:12px;padding:.6rem .9rem;font-weight:700}
.sf-btn.gray{background:#1f2937;color:#e5e7eb}
