  box-shadow:
    0 0 0 3px rgba(34,197,94,.18),
    0 10px 24px -14px rgba(16,185,129,.35);
  opacity: 1;                            /* don’t dim finished items */
  animation: doneGlow 1.2s ease-out 1;
}

