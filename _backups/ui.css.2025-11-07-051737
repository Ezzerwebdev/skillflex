.sf-quiz-q{margin:0 0 10px 0;font-weight:800}
.sf-quiz-opt{display:block;margin:8px 0;padding:.6rem .8rem;border-radius:12px;border:1px solid rgba(255,255,255,.08);cursor:pointer;background:rgba(255,255,255,.03)}
.sf-quiz-opt:hover{background:rgba(255,255,255,.06)}
