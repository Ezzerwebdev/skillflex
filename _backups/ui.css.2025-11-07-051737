  margin-left: .5rem;
  font-size: .75rem;
  font-weight: 800;
  color: #065f46;
  background: #dcfce7;
  border: 1px solid #86efac;
  padding: .1rem .4rem;
  border-radius: 999px;
}

/* Keep locked distinct (your existing look is fine) */
.activity-card.locked { opacity: .6; filter: grayscale(.3); }

/* Motion */
@keyframes cardNudge {
  0% { transform: translateY(0); }
  50% { transform: translateY(-2px); }
  100% { transform: translateY(0); }
}

/* Respect reduced motion */
@media (prefers-reduced-motion: reduce) {
