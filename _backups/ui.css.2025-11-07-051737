/* --- Home scaffold & Continue card --- */
#hubGrid{
  display:grid;
  grid-template-columns: 1fr;   /* ← single column = visually centered */
  gap:24px;
  align-items:start;
}

#hubMain{ min-width:0; }
#motivationRail{ position:sticky; top:84px; display:flex; flex-direction:column; gap:12px; }

@media (max-width:1024px){
  #hubGrid{ grid-template-columns:1fr; }
  #motivationRail{ position:static; }
}

/* Continue / Resume card (brand default) */
.continue-card{
  border-radius: var(--radius-xl);
  padding: 16px 18px;
  background: var(--brand-grad);          /* ← match header/buttons */
  color: #fff;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
}

/* soft sheen so white text always reads on gradients */
.continue-card::after{
  content:"";
  position:absolute; inset:0;
  background:
    radial-gradient(120% 180% at 100% 0%, rgba(255,255,255,.24), transparent 50%),
    linear-gradient(0deg, rgba(0,0,0,.12), transparent 40%);
  mix-blend-mode: overlay;
  pointer-events:none;
}

/* headline + pills inside the card */
.continue-card h2, .continue-card .title{
  margin: 0 0 .5rem;
  color:#fff;
  font-family: var(--display-font);
  letter-spacing:.2px;
}
.continue-card .pill{
  background: rgba(255,255,255,.16);
  border: 1px solid rgba(255,255,255,.28);
  color:#fff;
}
.continue-card .btn{
  border-radius: var(--radius-lg);
  background:#fff; color:#1f2937;            /* high-contrast CTA on gradient */
  box-shadow: var(--shadow);
}
.continue-card .btn:hover{ transform:none; }  /* premium = steadier CTA */

.section.continue-card{
  background: var(--brand-grad);
  color:#fff;
  border:0;
  box-shadow: var(--elev-2);
}

/* --- Unit tiles: restore crisp frame + radius --- */

/* 1) Fix typos (if you keep the original blocks, this ensures radius always applies) */
.selection-card,
.activity-card,
.grownups-card,
.skel { border-radius: var(--radius-lg); }

/* 2) Stronger default card frame */
.activity-card{
  border: 2px solid #E6EAF5;           /* crisper than #e9edf9 */
  background:#fff;
  box-shadow: var(--elev-1);
}

/* 3) Hover should feel premium, not float away */
.activity-card:hover{
  transform: translateY(-2px);
  box-shadow: var(--elev-2);
  border-color: #D6DBEE;               /* subtle lift */
}

/* 4) Keep the CURRENT step obvious, regardless of other classes present */
.activity-card.current{
  background: #F1FBF6;                 /* gentle mint fill */
  border-color: #86EFAE;
  box-shadow: 0 8px 20px rgba(16,185,129,.15);
}

/* 5) Locked shouldn’t look dead; keep the edge visible */
.activity-card.locked{
  background:#FBFCFF;
  border-color:#E5E7EB;
  opacity:.85;                          /* was .6 */
  filter: grayscale(.15);               /* was .3 */
}

/* 6) Completed stays positive (no heavy dim) */
.activity-card.completed{
  opacity: 1;
  background:#F0FDF4;
  border-color:#86EFAC;
}

/* Optional: stronger frame just inside Units sections, if you use a wrapper class */
.section .activity-card{ border-color:#E2E8F0; }

/* === Unit tiles: restore mint edge + glow (must stay last) === */
.activity-card.core-card{
  background: var(--unit-bg);
  border: 2px solid var(--unit-edge-soft);
  border-radius: var(--radius-lg);
  box-shadow:
    0 0 0 2px rgba(134,239,172,.28) inset,
    0 10px 24px -16px var(--unit-glow);
}

.activity-card.core-card.current{
  background: #ecfdf5;
  border-color: var(--unit-edge);
  box-shadow:
    0 0 0 2px rgba(134,239,172,.38) inset,
    0 12px 26px -14px var(--unit-glow);
}

.activity-card.core-card.completed{
  background: #ecfdf5;
  border: 2px solid var(--unit-edge);
  box-shadow:
    0 0 0 3px rgba(34,197,94,.18),
    0 12px 26px -16px rgba(16,185,129,.32);
}

/* guard: never let a generic frame wash these out */
.activity-card.core-card { border-image: initial; }



