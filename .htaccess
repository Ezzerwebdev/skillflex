# Default doc + avoid MultiViews quirks
DirectoryIndex index.html
Options -MultiViews

# ------------ SPA routing + static pass-through ------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1) Serve any static asset as-is (no SPA fallback)
  RewriteCond %{REQUEST_URI} \.(?:js|mjs|css|map|json|webmanifest|svg|png|jpe?g|gif|webp|ico|woff2?|mp3|mp4)$ [NC]
  RewriteRule ^ - [L]

  # 2) Serve existing files/directories as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3) Fallback everything else to index.html (SPA)
  RewriteRule . index.html [L]
</IfModule>

# ------------ MIME types (avoid "text/html" for JS) ------------
<IfModule mod_mime.c>
  AddType text/javascript .js
  AddType application/javascript .mjs
  AddType application/json .json
  AddType application/manifest+json .webmanifest
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType audio/mpeg .mp3
</IfModule>

# ------------ Security / CORS (safe defaults) ------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Allow reading packs JSON cross-origin if you ever host elsewhere (optional)
  Header set Access-Control-Allow-Origin "*" "expr=%{REQUEST_URI} =~ m#^/packs/#"
  Header set Access-Control-Allow-Methods "GET, OPTIONS" "expr=%{REQUEST_URI} =~ m#^/packs/#"
</IfModule>

# ------------ Caching ------------
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML: no cache
  ExpiresByType text/html "access plus 0 seconds"
  # Static long cache
  ExpiresByType text/css                 "access plus 1 year"
  ExpiresByType text/javascript          "access plus 1 year"
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType image/svg+xml            "access plus 1 year"
  ExpiresByType image/webp               "access plus 1 year"
  ExpiresByType audio/mpeg               "access plus 1 year"
  # Data (short)
  ExpiresByType application/json         "access plus 5 minutes"
  ExpiresByType application/manifest+json "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs|css|svg|webp|mp3)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(json|webmanifest)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-store, max-age=0"
  </FilesMatch>
</IfModule>
